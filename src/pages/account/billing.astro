---
import BillingDashboard from "@/components/BillingDashboard";
import BillingDashboardFallback from "@/components/BillingDashboardFallback.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import Layout from "@/layouts/Layout.astro";
import { requireUser } from "@/lib/server/require-user";
import { getUserPlan } from "@/server/lib/entitlements";

const requiredUser = requireUser(Astro);

if (requiredUser instanceof Response) {
  return requiredUser;
}

const autoCheckout = Astro.url.searchParams.get("checkout") === "pro";
const { plan } = await getUserPlan(requiredUser.id);
---

<Layout description="Manage billing and plan limits." title="Billing | Tranzfer">
  <div class="min-h-[100dvh]">
    <SiteHeader currentPath="/account/billing" user={requiredUser} />

    <main class="px-5 pb-16 pt-28 sm:px-8 lg:pt-32">
      <div class="mx-auto max-w-[1200px]">
        <BillingDashboard
          client:load
          autoCheckout={autoCheckout}
          currentPlan={plan}
          userEmail={requiredUser.email}
          userName={requiredUser.name}
        >
          <BillingDashboardFallback slot="fallback" />
        </BillingDashboard>
      </div>
    </main>
  </div>
</Layout>
