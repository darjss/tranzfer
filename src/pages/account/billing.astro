---
import BillingDashboard from "@/components/BillingDashboard";
import BillingDashboardFallback from "@/components/BillingDashboardFallback.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import Layout from "@/layouts/Layout.astro";
import { requireUser } from "@/lib/server/require-user";
import { getBillingProductIds } from "@/server/lib/billing-config";

const requiredUser = requireUser(Astro);

if (requiredUser instanceof Response) {
  return requiredUser;
}

const productIds = getBillingProductIds();
---

<Layout description="Manage billing, current plan, and Polar customer portal access." title="Billing | Threadline Starter">
  <div class="min-h-[100dvh] bg-[linear-gradient(180deg,#f5f1e8_0%,#f8f7f4_44%,#ffffff_100%)] text-zinc-950">
    <SiteHeader currentPath="/account/billing" user={requiredUser} />

    <main class="px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
      <div class="mx-auto max-w-[1120px]">
        <BillingDashboard
          client:only="solid-js"
          productIds={productIds}
          userEmail={requiredUser.email}
          userName={requiredUser.name}
        >
          <BillingDashboardFallback slot="fallback" />
        </BillingDashboard>
      </div>
    </main>
  </div>
</Layout>
