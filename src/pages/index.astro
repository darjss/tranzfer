---
import PricingSection from "@/components/PricingSection";
import PricingSectionFallback from "@/components/PricingSectionFallback.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import Layout from "@/layouts/Layout.astro";
import { getBillingProductIds } from "@/server/lib/billing-config";

const productIds = getBillingProductIds();
const user = Astro.locals.user;

const featureRail = [
  {
    detail: "Checkout, portal access, and webhook handling all stay under Better Auth.",
    title: "Billing lives inside the same auth boundary",
  },
  {
    detail: "Polar checkout is wired for recurring subscriptions without adding custom billing tables.",
    title: "Recurring billing without extra backend inventory",
  },
  {
    detail: "The same starter now covers marketing, signup, checkout, and account billing.",
    title: "One codebase from landing page to paid account",
  },
];

const deliverySteps = [
  {
    body: "Start users on Starter at $9/month with one workspace and five seats.",
    step: "Launch the base plan",
  },
  {
    body: "Upgrade to Pro at $29/month when teams need more seats, more workspaces, and priority support.",
    step: "Open the expansion path",
  },
  {
    body: "Use the billing page soft-gate to show upgrade pressure before you hard-enforce limits in APIs.",
    step: "Grow into enforcement later",
  },
];
---

<Layout
  description="Threadline starter with Better Auth, Polar checkout, Astro, and Cloudflare in one repo."
  title="Threadline Starter"
>
  <div class="min-h-[100dvh] bg-[linear-gradient(180deg,#f5f1e8_0%,#f8f7f4_44%,#ffffff_100%)] text-zinc-950">
    <SiteHeader currentPath="/" user={user} />

    <main>
      <section class="px-4 pb-16 pt-10 sm:px-6 lg:px-8 lg:pb-20 lg:pt-14">
        <div class="mx-auto grid max-w-[1120px] gap-10 lg:grid-cols-[0.94fr_1.06fr] lg:items-end lg:gap-14">
          <div class="max-w-2xl">
            <div class="inline-flex items-center gap-2 rounded-full border border-zinc-300/80 bg-white/85 px-3 py-1.5 text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-zinc-600 shadow-[inset_0_1px_0_rgba(255,255,255,0.85)]">
              <span class="h-2 w-2 rounded-full bg-amber-600"></span>
              Astro, Better Auth, Polar, Cloudflare
            </div>

            <h1 class="mt-8 text-5xl font-semibold tracking-[-0.06em] text-zinc-950 sm:text-6xl lg:text-[5.4rem] lg:leading-[0.94]">
              Sell Starter and Pro from the same app that runs your product.
            </h1>

            <p class="mt-6 max-w-[40rem] text-base leading-relaxed text-zinc-600 sm:text-lg">
              This starter now includes authenticated Polar checkout, Better Auth customer wiring,
              a billing portal, and account-side plan state without adding a second app or a custom
              billing backend.
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
              <a
                class="rounded-2xl border border-zinc-900 bg-zinc-950 px-5 py-3 text-sm font-medium text-zinc-50 transition-colors hover:bg-zinc-800"
                href="/pricing"
              >
                View pricing
              </a>
              <a
                class="rounded-2xl border border-zinc-300 bg-white px-5 py-3 text-sm font-medium text-zinc-900 transition-colors hover:border-zinc-400"
                href={user ? "/account/billing" : "/auth/sign-up?plan=starter"}
              >
                {user ? "Open billing" : "Start Starter"}
              </a>
            </div>
          </div>

          <div class="grid gap-4">
            {featureRail.map((item, index) => (
              <div
                class:list={[
                  "rounded-[1.75rem] border p-6 shadow-[0_24px_60px_-42px_rgba(24,24,27,0.22)]",
                  index === 1 ? "border-zinc-900 bg-zinc-950 text-zinc-50" : "border-zinc-200 bg-white/92 text-zinc-950",
                ]}
              >
                <div
                  class:list={[
                    "text-[0.72rem] font-semibold uppercase tracking-[0.26em]",
                    index === 1 ? "text-zinc-400" : "text-zinc-500",
                  ]}
                >
                  0{index + 1}
                </div>
                <h2 class="mt-4 text-2xl font-semibold tracking-tight">{item.title}</h2>
                <p
                  class:list={[
                    "mt-3 text-sm leading-relaxed",
                    index === 1 ? "text-zinc-300" : "text-zinc-600",
                  ]}
                >
                  {item.detail}
                </p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="px-4 py-8 sm:px-6 lg:px-8 lg:py-12">
        <div class="mx-auto max-w-[1120px]">
          <PricingSection
            client:only="solid-js"
            description="Public plan cards route new users through sign-up first, then continue directly into Polar checkout."
            productIds={productIds}
            title="Two recurring plans, one checkout path"
          >
            <PricingSectionFallback
              slot="fallback"
              description="Public plan cards route new users through sign-up first, then continue directly into Polar checkout."
              title="Two recurring plans, one checkout path"
            />
          </PricingSection>
        </div>
      </section>

      <section class="px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
        <div class="mx-auto grid max-w-[1120px] gap-8 lg:grid-cols-[0.8fr_1.2fr]">
          <div class="max-w-md">
            <div class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-zinc-500">
              Delivery path
            </div>
            <h2 class="mt-4 text-3xl font-semibold tracking-[-0.05em] text-zinc-950 sm:text-4xl">
              Start with conversion, then keep the same billing language inside the app.
            </h2>
            <p class="mt-4 text-base leading-relaxed text-zinc-600">
              The point is not just to show pricing. The point is to carry plan state, checkout,
              and account management through the same product surface.
            </p>
          </div>

          <div class="grid gap-4">
            {deliverySteps.map((item, index) => (
              <div class="grid gap-4 rounded-[1.75rem] border border-zinc-200 bg-white/92 p-6 shadow-[0_22px_55px_-40px_rgba(24,24,27,0.22)] sm:grid-cols-[120px_1fr] sm:p-7">
                <div class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-zinc-500">
                  Step 0{index + 1}
                </div>
                <div>
                  <h3 class="text-xl font-semibold tracking-tight text-zinc-950">{item.step}</h3>
                  <p class="mt-2 max-w-[42rem] text-sm leading-relaxed text-zinc-600">
                    {item.body}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    </main>
  </div>
</Layout>
