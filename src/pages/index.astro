---
import PricingSection from "@/components/PricingSection";
import PricingSectionFallback from "@/components/PricingSectionFallback.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import Layout from "@/layouts/Layout.astro";

const user = Astro.locals.user;

const highlights = [
  {
    detail: "No clunky portals. Your recipient gets a cinematic presentation of your work, not a login wall. Your art remains the focal point.",
    title: "Zero Friction Delivery",
  },
  {
    detail: "Metadata, billing, and expiry operate on edge networks. Upload directly to Cloudflare R2. Ridiculously fast, globally distributed.",
    title: "Edge-Native Infrastructure",
  },
  {
    detail: "We don't charge you for breathing. Move to the Pro tier only when your RAWs or 8K timelines outgrow our generous defaults.",
    title: "Pay For Gravity",
  },
];
---

<Layout
  description="Tranzfer is a high-end delivery protocol for photographers, editors, and studios."
  title="Tranzfer | The Cinematic Delivery Protocol"
>
  <div class="min-h-[100dvh] relative selection:bg-electric selection:text-white">
    <!-- Abstract blurred background elements -->
    <div class="fixed top-0 left-0 w-full h-full overflow-hidden pointer-events-none z-[-1]">
      <div class="absolute top-[-10%] right-[-5%] w-[50vw] h-[50vw] rounded-full bg-electric/10 blur-[120px] animate-pulse-soft"></div>
      <div class="absolute bottom-[-10%] left-[-10%] w-[60vw] h-[60vw] rounded-full bg-zinc-900/80 blur-[100px]"></div>
    </div>

    <SiteHeader currentPath="/" user={user} />

    <main class="relative z-10">
      <section class="min-h-[100dvh] flex flex-col justify-center px-6 pt-32 pb-20 lg:px-12">
        <div class="mx-auto w-full max-w-[1600px] grid lg:grid-cols-[1.1fr_0.9fr] gap-16 lg:gap-24 items-center">
          
          <!-- Left: Massive Typography -->
          <div class="max-w-3xl animate-fade-up">
            <div class="inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-[0.65rem] font-bold uppercase tracking-[0.3em] text-zinc-300 backdrop-blur-md">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-electric opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-electric"></span>
              </span>
              Built for Visual Artists
            </div>

            <h1 class="mt-10 text-[3.5rem] font-medium leading-[0.9] tracking-[-0.05em] text-white sm:text-7xl lg:text-[6.5rem]">
              Deliver your <br/>
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-zinc-300 via-white to-zinc-600 italic font-serif">masterpiece.</span>
            </h1>

            <p class="mt-8 max-w-[32rem] text-lg leading-relaxed text-zinc-400 font-light text-balance">
              WeTransfer is basic. Tranzfer is a high-performance, edge-native protocol designed specifically for photographers, videographers, and creative studios who refuse to compromise on presentation.
            </p>

            <div class="mt-12 flex flex-wrap items-center gap-4">
              <a
                class="group relative inline-flex items-center justify-center rounded-full bg-white px-8 py-4 text-sm font-bold uppercase tracking-[0.1em] text-zinc-950 transition-all duration-500 hover:scale-[1.02] hover:shadow-[0_0_40px_rgba(255,255,255,0.3)] active:scale-95 overflow-hidden"
                href={user ? "/account/transfers" : "/auth/sign-up"}
              >
                <div class="absolute inset-0 bg-zinc-200 translate-y-[100%] group-hover:translate-y-[0%] transition-transform duration-300 ease-out z-0"></div>
                <span class="relative z-10 flex items-center gap-2">
                  {user ? "Open Protocol" : "Initiate Transfer"}
                  <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M5 12h14M12 5l7 7-7 7" />
                  </svg>
                </span>
              </a>
              <a
                class="group inline-flex items-center justify-center rounded-full px-8 py-4 text-sm font-bold uppercase tracking-[0.1em] text-zinc-400 transition-all duration-300 hover:text-white"
                href="/pricing"
              >
                <span class="relative">
                  View Specs
                  <span class="absolute -bottom-1 left-0 w-0 h-px bg-white transition-all duration-300 group-hover:w-full"></span>
                </span>
              </a>
            </div>
          </div>

          <!-- Right: Asymmetric Bento Visuals -->
          <div class="relative w-full h-[500px] lg:h-[750px] animate-fade-in delay-200 mt-12 lg:mt-0">
            <div class="absolute top-0 right-0 w-[85%] h-[75%] rounded-[2rem] overflow-hidden glass-panel transform rotate-1 hover:rotate-0 transition-all duration-700 hover:scale-105 z-20 shadow-2xl">
              <img src="https://images.unsplash.com/photo-1542038784456-1ea8e935640e?q=80&w=2070&auto=format&fit=crop" alt="Photography Workspace" class="w-full h-full object-cover opacity-80 mix-blend-luminosity grayscale hover:grayscale-0 transition-all duration-1000" />
              <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-transparent to-transparent opacity-80"></div>
              <div class="absolute bottom-8 left-8">
                <div class="text-[0.65rem] font-mono tracking-[0.2em] text-white/50 mb-2">01 // VISUALS</div>
                <div class="text-2xl font-medium tracking-tight text-white">Lossless Quality</div>
              </div>
            </div>

            <div class="absolute bottom-0 left-0 w-[70%] h-[45%] rounded-[2rem] overflow-hidden liquid-glass transform -rotate-2 hover:rotate-0 transition-all duration-700 hover:scale-105 z-30 shadow-[0_30px_60px_rgba(0,0,0,0.6)]">
              <div class="w-full h-full flex flex-col justify-between p-7 relative">
                <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=2000&auto=format&fit=crop')] bg-cover bg-center opacity-20 mix-blend-overlay"></div>
                <div class="relative z-10 flex justify-between items-start">
                  <div class="flex gap-2">
                    <div class="w-2.5 h-2.5 rounded-full bg-zinc-700 border border-zinc-500"></div>
                    <div class="w-2.5 h-2.5 rounded-full bg-zinc-700 border border-zinc-500"></div>
                    <div class="w-2.5 h-2.5 rounded-full bg-zinc-700 border border-zinc-500"></div>
                  </div>
                  <div class="text-[0.65rem] font-mono text-zinc-400 tracking-[0.15em] px-2 py-1 rounded-md bg-white/5 border border-white/10">TRANSFER_ACTIVE</div>
                </div>
                
                <div class="relative z-10 mt-auto">
                  <div class="flex justify-between text-xs font-mono text-zinc-400 mb-3">
                    <span class="tracking-tight text-zinc-300">FINAL_CUT_V3.MP4</span>
                    <span class="text-white font-bold">68%</span>
                  </div>
                  <div class="h-1.5 w-full bg-zinc-800 rounded-full overflow-hidden">
                    <div class="h-full bg-white w-[68%] rounded-full relative">
                      <div class="absolute top-0 right-0 w-16 h-full bg-electric/50 blur-[2px] animate-marquee"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            
            <div class="absolute top-[20%] left-[-5%] w-[40%] h-[40%] rounded-full bg-electric/15 blur-[80px] z-10 animate-float"></div>
          </div>
        </div>
      </section>

      <!-- Divider -->
      <div class="w-full h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

      <section class="px-6 py-32 lg:px-12 relative">
        <div class="mx-auto max-w-[1600px]">
          <div class="mb-20 flex flex-col md:flex-row md:items-end justify-between gap-8">
            <h2 class="text-4xl md:text-6xl font-medium tracking-tight text-white leading-none">
              Engineering <br/>
              <span class="italic font-serif text-zinc-500">excellence.</span>
            </h2>
            <p class="text-zinc-400 max-w-md text-sm leading-relaxed">
              We stripped out every unnecessary feature to give you pure, unadulterated delivery speed. The result is a radically simplified architecture.
            </p>
          </div>
          <div class="grid md:grid-cols-3 gap-6 lg:gap-10">
            {highlights.map((item, index) => (
              <div class="group relative p-10 rounded-[2.5rem] glass-panel overflow-hidden transition-all duration-700 hover:bg-zinc-900/90 hover:-translate-y-2">
                <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-white/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 transform -translate-x-full group-hover:translate-x-full ease-in-out"></div>
                <div class="text-[0.7rem] font-mono font-bold tracking-[0.3em] text-zinc-600 mb-8 transition-colors duration-500 group-hover:text-white">
                  {String(index + 1).padStart(2, '0')} // FEATURE
                </div>
                <h3 class="text-2xl font-medium tracking-tight text-white mb-5">
                  {item.title}
                </h3>
                <p class="text-zinc-400 leading-relaxed text-[0.95rem] font-light">
                  {item.detail}
                </p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="px-6 py-32 lg:px-12 relative overflow-hidden">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[100vw] h-[100vw] bg-white/[0.01] rounded-full blur-[120px] pointer-events-none"></div>
        <div class="mx-auto max-w-[1200px] relative z-10">
          <PricingSection
            client:load
            description="Start free, authenticate securely, and scale into Pro only when your art demands it."
            title="Surgical Pricing."
          >
            <PricingSectionFallback
              slot="fallback"
              description="Start free, authenticate securely, and scale into Pro only when your art demands it."
              title="Surgical Pricing."
            />
          </PricingSection>
        </div>
      </section>
    </main>
  </div>
</Layout>
