---
import PricingSection from "@/components/PricingSection";
import PricingSectionFallback from "@/components/PricingSectionFallback.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import Layout from "@/layouts/Layout.astro";
import { getBillingProductIds } from "@/server/lib/billing-config";

const productIds = getBillingProductIds();
const user = Astro.locals.user;
---

<Layout
  description="Public pricing for the Threadline starter with Polar checkout."
  title="Pricing | Threadline Starter"
>
  <div class="min-h-[100dvh] bg-[linear-gradient(180deg,#f5f1e8_0%,#f8f7f4_44%,#ffffff_100%)] text-zinc-950">
    <SiteHeader currentPath="/pricing" user={user} />

    <main class="px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
      <div class="mx-auto max-w-[1120px]">
        <PricingSection
          client:only="solid-js"
          description="Choose Starter for the first team or Pro for higher limits. New users authenticate first, then continue straight into Polar checkout."
          productIds={productIds}
          title="Pick the plan that matches the current stage of the product"
        >
          <PricingSectionFallback
            slot="fallback"
            description="Choose Starter for the first team or Pro for higher limits. New users authenticate first, then continue straight into Polar checkout."
            title="Pick the plan that matches the current stage of the product"
          />
        </PricingSection>
      </div>
    </main>
  </div>
</Layout>
