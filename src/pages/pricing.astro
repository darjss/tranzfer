---
import PricingSection from "@/components/PricingSection";
import PricingSectionFallback from "@/components/PricingSectionFallback.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import Layout from "@/layouts/Layout.astro";

const user = Astro.locals.user;
---

<Layout
  description="Pricing for Tranzfer large-file delivery."
  title="Pricing | Tranzfer"
>
  <div class="min-h-[100dvh]">
    <SiteHeader currentPath="/pricing" user={user} />

    <main class="px-5 pb-16 pt-28 sm:px-8 lg:pt-32">
      <div class="mx-auto max-w-[1200px]">
        <PricingSection
          client:load
          description="Free gets you moving quickly. Pro expands transfer size and active storage without changing the sending flow."
          title="Pricing for delivery work, not bloated file portals"
        >
          <PricingSectionFallback
            slot="fallback"
            description="Free gets you moving quickly. Pro expands transfer size and active storage without changing the sending flow."
            title="Pricing for delivery work, not bloated file portals"
          />
        </PricingSection>
      </div>
    </main>
  </div>
</Layout>
