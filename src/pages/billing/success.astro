---
import CheckoutSuccess from "@/components/CheckoutSuccess";
import SiteHeader from "@/components/SiteHeader.astro";
import Layout from "@/layouts/Layout.astro";
import { requireUser } from "@/lib/server/require-user";
import { getBillingProductIds } from "@/server/lib/billing-config";

const requiredUser = requireUser(Astro);

if (requiredUser instanceof Response) {
  return requiredUser;
}

const checkoutId = Astro.url.searchParams.get("checkout_id");
const productIds = getBillingProductIds();
---

<Layout description="Checkout completed. Syncing Polar customer state." title="Checkout Success | Threadline Starter">
  <div class="min-h-[100dvh] bg-[linear-gradient(180deg,#f5f1e8_0%,#f8f7f4_44%,#ffffff_100%)] text-zinc-950">
    <SiteHeader currentPath="/billing/success" user={requiredUser} />

    <main class="px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
      <div class="mx-auto max-w-[920px]">
        <CheckoutSuccess client:load checkoutId={checkoutId} productIds={productIds} />
      </div>
    </main>
  </div>
</Layout>
