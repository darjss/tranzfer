---
import CheckoutSuccess from "@/components/CheckoutSuccess";
import SiteHeader from "@/components/SiteHeader.astro";
import Layout from "@/layouts/Layout.astro";
import { requireUser } from "@/lib/server/require-user";

const requiredUser = requireUser(Astro);

if (requiredUser instanceof Response) {
  return requiredUser;
}

const checkoutId = Astro.url.searchParams.get("checkout_id");
---

<Layout description="Your Pro checkout is complete." title="Checkout Success | Tranzfer">
  <div class="min-h-[100dvh]">
    <SiteHeader currentPath="/billing/success" user={requiredUser} />

    <main class="px-5 pb-16 pt-28 sm:px-8 lg:pt-32">
      <div class="mx-auto max-w-[920px]">
        <CheckoutSuccess client:load checkoutId={checkoutId} />
      </div>
    </main>
  </div>
</Layout>
