---
import "../styles/global.css";

const description =
  Astro.props.description ||
  "Tranzfer is a high-end delivery protocol for photographers, editors, and studios. Send massive files without friction.";
const title = Astro.props.title || "Tranzfer | The Cinematic Delivery Protocol";
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-background text-foreground antialiased selection:bg-electric selection:text-white">
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    min-height: 100dvh;
  }
</style>
