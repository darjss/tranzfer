<section class="grid gap-6">
  <div class="rounded-2xl border border-white/[0.06] bg-white/[0.03] p-7 shadow-[inset_0_1px_0_rgba(255,255,255,0.06),0_28px_90px_-30px_rgba(0,0,0,0.5)] backdrop-blur-xl sm:p-9">
    <div class="h-3 w-24 rounded-full bg-zinc-800 animate-shimmer bg-gradient-to-r from-zinc-800 via-zinc-700 to-zinc-800 bg-[length:200%_100%]"></div>
    <div class="mt-5 h-10 w-72 rounded-xl bg-white/[0.04]"></div>
    <div class="mt-3 h-4 w-full max-w-xl rounded-full bg-white/[0.03]"></div>

    <div class="mt-9 grid gap-5 lg:grid-cols-[0.92fr_1.08fr]">
      <div class="rounded-xl border border-white/[0.06] bg-white/[0.03] p-5">
        <div class="h-4 w-24 rounded-full bg-white/[0.04]"></div>
        <div class="mt-4 h-10 w-40 rounded-xl bg-white/[0.06]"></div>
        <div class="mt-6 space-y-3">
          {[1, 2, 3].map(() => (
            <div class="flex items-center justify-between gap-4">
              <div class="h-3 w-32 rounded-full bg-white/[0.04]"></div>
              <div class="h-3 w-24 rounded-full bg-white/[0.06]"></div>
            </div>
          ))}
        </div>
      </div>

      <div class="rounded-xl border border-white/[0.06] bg-white/[0.02] p-5">
        {[1, 2, 3].map(() => (
          <div class="mt-4 first:mt-0">
            <div class="h-4 w-24 rounded-full bg-white/[0.04]"></div>
            <div class="mt-2 h-12 rounded-xl bg-white/[0.03]"></div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="rounded-2xl border border-white/[0.06] bg-white/[0.03] p-7 shadow-[inset_0_1px_0_rgba(255,255,255,0.06),0_26px_80px_-30px_rgba(0,0,0,0.5)] backdrop-blur-xl sm:p-9">
    <div class="h-3 w-24 rounded-full bg-zinc-800 animate-shimmer bg-gradient-to-r from-zinc-800 via-zinc-700 to-zinc-800 bg-[length:200%_100%]"></div>
    <div class="mt-5 h-9 w-64 rounded-xl bg-white/[0.04]"></div>
    <div class="mt-8 grid gap-4">
      {[1, 2].map(() => (
        <div class="rounded-xl border border-white/[0.06] bg-white/[0.03] p-5">
          <div class="h-5 w-56 rounded-full bg-white/[0.04]"></div>
          <div class="mt-3 h-4 w-full rounded-full bg-white/[0.03]"></div>
          <div class="mt-5 h-10 rounded-xl bg-white/[0.02]"></div>
        </div>
      ))}
    </div>
  </div>
</section>
