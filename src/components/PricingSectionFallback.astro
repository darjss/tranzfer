---
const {
  description,
  title,
} = Astro.props;
---

<section class="rounded-2xl border border-white/[0.06] bg-white/[0.03] p-7 shadow-[inset_0_1px_0_rgba(255,255,255,0.06),0_30px_80px_-30px_rgba(0,0,0,0.5)] backdrop-blur-xl sm:p-9">
  <div class="max-w-2xl">
    <div class="font-mono text-[0.68rem] font-medium uppercase tracking-[0.28em] text-zinc-600">
      Plans
    </div>
    <h2 class="mt-5 text-3xl font-semibold tracking-[-0.03em] text-zinc-100 sm:text-4xl">
      {title}
    </h2>
    <p class="mt-4 max-w-[42rem] text-base leading-relaxed text-zinc-400">
      {description}
    </p>
  </div>

  <div class="mt-9 grid gap-5 lg:grid-cols-2">
    {["free", "pro"].map((planKey) => (
      <div
        class:list={[
          "flex h-full flex-col rounded-2xl border p-6",
          planKey === "pro"
            ? "border-copper/20 bg-copper/[0.06]"
            : "border-white/[0.06] bg-white/[0.03]",
        ]}
      >
        <div class:list={[
          "h-3 w-16 rounded-full animate-shimmer",
          planKey === "pro" ? "bg-gradient-to-r from-copper/20 via-copper/40 to-copper/20" : "bg-gradient-to-r from-zinc-800 via-zinc-700 to-zinc-800",
        ]}></div>
        <div class:list={[
          "mt-4 h-10 w-32 rounded-xl",
          planKey === "pro" ? "bg-copper/10" : "bg-white/[0.04]",
        ]}></div>

        <div class:list={[
          "mt-5 h-20 rounded-xl border",
          planKey === "pro"
            ? "border-copper/15 bg-copper/[0.04]"
            : "border-white/[0.06] bg-white/[0.02]",
        ]}></div>

        <div class="mt-5 space-y-3">
          {[1, 2, 3].map(() => (
            <div class="flex items-center gap-3">
              <div class:list={[
                "h-1.5 w-1.5 rounded-full",
                planKey === "pro" ? "bg-copper/50" : "bg-zinc-700",
              ]}></div>
              <div class:list={[
                "h-3 flex-1 rounded-full",
                planKey === "pro" ? "bg-copper/10" : "bg-white/[0.04]",
              ]}></div>
            </div>
          ))}
        </div>

        <div class:list={[
          "mt-6 h-11 w-full rounded-xl",
          planKey === "pro" ? "bg-copper/20" : "bg-white/[0.06]",
        ]}></div>
      </div>
    ))}
  </div>
</section>
