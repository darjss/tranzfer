<section class="rounded-2xl border border-white/[0.06] bg-white/[0.03] p-7 shadow-[inset_0_1px_0_rgba(255,255,255,0.06),0_28px_75px_-30px_rgba(0,0,0,0.5)] backdrop-blur-xl sm:p-9">
  <div class="h-3 w-16 rounded-full bg-zinc-800 animate-shimmer bg-gradient-to-r from-zinc-800 via-zinc-700 to-zinc-800 bg-[length:200%_100%]"></div>
  <div class="mt-5 h-10 w-56 rounded-xl bg-white/[0.04]"></div>
  <div class="mt-3 h-4 w-full max-w-lg rounded-full bg-white/[0.03]"></div>

  <div class="mt-9 grid gap-5 lg:grid-cols-[0.95fr_1.05fr]">
    <div class="rounded-xl border border-white/[0.06] bg-white/[0.03] p-5">
      <div class="h-4 w-24 rounded-full bg-white/[0.04]"></div>
      <div class="mt-3 h-9 w-40 rounded-xl bg-white/[0.06]"></div>
      <div class="mt-6 space-y-3">
        {[1, 2, 3, 4].map(() => (
          <div class="flex items-center justify-between gap-4">
            <div class="h-3 w-28 rounded-full bg-white/[0.04]"></div>
            <div class="h-3 w-24 rounded-full bg-white/[0.06]"></div>
          </div>
        ))}
      </div>
    </div>

    <div class="rounded-xl border border-white/[0.06] bg-white/[0.02] p-5">
      {[1, 2, 3].map(() => (
        <div class="mt-4 first:mt-0 flex items-center gap-3 rounded-xl border border-white/[0.06] bg-white/[0.02] px-4 py-3">
          <div class="h-1.5 w-1.5 rounded-full bg-copper/40"></div>
          <div class="h-3 flex-1 rounded-full bg-white/[0.04]"></div>
        </div>
      ))}
    </div>
  </div>
</section>
