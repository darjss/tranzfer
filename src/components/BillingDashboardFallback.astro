<div class="grid gap-6">
  <section class="rounded-[2rem] border border-zinc-200 bg-white/92 p-6 shadow-[0_28px_75px_-42px_rgba(24,24,27,0.22)] sm:p-8">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div class="w-full max-w-xl">
        <div class="h-3 w-16 rounded-full bg-zinc-200" />
        <div class="mt-4 h-10 w-64 rounded-2xl bg-zinc-200" />
        <div class="mt-3 h-4 w-full max-w-md rounded-full bg-zinc-100" />
      </div>

      <div class="flex gap-3">
        <div class="h-11 w-32 rounded-2xl border border-zinc-200 bg-white" />
        <div class="h-11 w-24 rounded-2xl border border-zinc-200 bg-white" />
      </div>
    </div>

    <div class="mt-8 grid gap-5 lg:grid-cols-[0.92fr_1.08fr]">
      <div class="rounded-[1.6rem] border border-zinc-200 bg-[#f6f1e7] p-5">
        <div class="flex items-center justify-between gap-3">
          <div class="w-full">
            <div class="h-4 w-24 rounded-full bg-zinc-200" />
            <div class="mt-3 h-9 w-40 rounded-2xl bg-white/80" />
          </div>
          <div class="h-7 w-20 rounded-full border border-zinc-300 bg-white/80" />
        </div>
        <div class="mt-5 space-y-3">
          {[1, 2, 3, 4].map(() => (
            <div class="flex items-center justify-between gap-4">
              <div class="h-3 w-28 rounded-full bg-zinc-200" />
              <div class="h-3 w-24 rounded-full bg-zinc-300" />
            </div>
          ))}
        </div>
      </div>

      <div class="rounded-[1.6rem] border border-zinc-200 bg-white p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]">
        <div class="flex items-center justify-between gap-3">
          <div class="w-full">
            <div class="h-4 w-32 rounded-full bg-zinc-200" />
            <div class="mt-2 h-3 w-56 rounded-full bg-zinc-100" />
          </div>
          <div class="h-7 w-24 rounded-full border border-zinc-200 bg-zinc-50" />
        </div>
        <div class="mt-5 grid gap-4 sm:grid-cols-2">
          {[1, 2].map(() => (
            <div class="grid gap-2">
              <div class="h-4 w-20 rounded-full bg-zinc-200" />
              <div class="h-11 rounded-2xl bg-zinc-100" />
              <div class="h-3 w-28 rounded-full bg-zinc-100" />
            </div>
          ))}
        </div>
        <div class="mt-5 h-20 rounded-[1.3rem] border border-zinc-200 bg-zinc-50" />
      </div>
    </div>
  </section>

  <section class="grid gap-5 lg:grid-cols-2">
    {[1, 2].map((index) => (
      <div
        class:list={[
          "rounded-[1.75rem] border p-6 shadow-[0_22px_55px_-40px_rgba(24,24,27,0.22)]",
          index === 2
            ? "border-zinc-900 bg-zinc-950 text-zinc-50"
            : "border-zinc-200 bg-white text-zinc-950",
        ]}
      >
        <div class="flex items-start justify-between gap-3">
          <div class="w-full">
            <div class:list={[
              "h-3 w-16 rounded-full",
              index === 2 ? "bg-zinc-700" : "bg-zinc-300",
            ]} />
            <div class:list={[
              "mt-4 h-10 w-28 rounded-2xl",
              index === 2 ? "bg-zinc-800" : "bg-zinc-100",
            ]} />
          </div>
          <div class:list={[
            "h-7 w-20 rounded-full border",
            index === 2 ? "border-zinc-700 bg-zinc-900" : "border-zinc-200 bg-zinc-50",
          ]} />
        </div>

        <div class="mt-5 space-y-3">
          {[1, 2, 3].map(() => (
            <div class="flex items-center gap-3">
              <div class:list={[
                "h-2 w-2 rounded-full",
                index === 2 ? "bg-amber-300" : "bg-amber-600",
              ]} />
              <div class:list={[
                "h-3 flex-1 rounded-full",
                index === 2 ? "bg-zinc-800" : "bg-zinc-200",
              ]} />
            </div>
          ))}
        </div>

        <div class="mt-6 h-11 w-40 rounded-2xl bg-zinc-900/10" />
      </div>
    ))}
  </section>
</div>
